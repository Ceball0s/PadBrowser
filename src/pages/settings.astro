---
import Layout from '../components/Layout.astro'
---
<Layout title="Opciones">
  <div class="steam-homepage settings-page has-custom-focus" id="hp">
    <div class="header">
      <div class="title-section">
        <h1 data-i18n="settings.title">Opciones</h1>
      </div>
      <div class="hdr-btns">
        <button class="close-btn" data-action="close" aria-label="Cerrar" data-i18n-arialabel="settings.close" tabindex="0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <div class="options-container">
      <button class="steam-card option-row variant-tornasol" data-action="toggle-console-mode" tabindex="0">
        <span class="option-label" data-i18n="settings.consoleMode">Modo consola</span>
        <span class="option-value" id="consoleMode">OFF</span>
      </button>
      
      <button class="steam-card option-row variant-tornasol" data-action="toggle-auto-keyboard" tabindex="0">
        <span class="option-label" data-i18n="settings.virtualKeyboard">Teclado virtual</span>
        <span class="option-value" id="autoKeyboard">OFF</span>
      </button>
      
      <button class="steam-card option-row variant-tornasol" data-action="pick-download-folder" tabindex="0">
        <span class="option-label" data-i18n="settings.downloadFolder">Carpeta de descargas</span>
        <span class="option-value folder-path" id="downloadFolder">—</span>
      </button>

      <button class="steam-card option-row variant-tornasol" data-action="show-tutorial" tabindex="0">
        <span class="option-label" data-i18n="settings.controlsGuide">Guía de controles</span>
        <span class="option-value">→</span>
      </button>

      <button class="steam-card option-row variant-tornasol" data-action="set-language" tabindex="0">
        <span class="option-label" data-i18n="settings.language">Idioma</span>
        <span class="option-value" id="currentLang" data-i18n="options.langName">Español</span>
      </button>

      <div class="footer-section">
        <button class="steam-card quit-btn variant-quit-tornasol" data-action="quit" tabindex="0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          <span data-i18n="settings.quit">Salir</span>
        </button>
      </div>
    </div>
  </div>

  <script id="init-data" type="application/json">{}</script>

  <script is:inline>
  void function(){
    var script = document.getElementById('init-data');
    var state = JSON.parse(script.textContent);

    function updateBadgeStyles(el, isActive) {
      if (!el) return;
      if (isActive) {
        el.classList.add('badge-active');
      } else {
        el.classList.remove('badge-active');
      }
    }

    window.__updateState = function(s) {
      state = s;
      var el = document.getElementById('consoleMode');
      if (el) {
        el.textContent = s.consoleMode ? window.__t('settings.on') : window.__t('settings.off');
        updateBadgeStyles(el, s.consoleMode);
      }
      el = document.getElementById('autoKeyboard');
      if (el) {
        el.textContent = s.autoKeyboard ? window.__t('settings.on') : window.__t('settings.off');
        updateBadgeStyles(el, s.autoKeyboard);
      }
      el = document.getElementById('downloadFolder');
      if (el) el.textContent = s.downloadFolder || window.__t('settings.dash');
    };

    if (state.consoleMode !== undefined) window.__updateState(state);

    document.querySelectorAll('[data-action]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        window.location.hash = '#action/' + btn.dataset.action;
      });
      btn.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          window.location.hash = '#action/' + btn.dataset.action;
        }
      });
    });
  }();
  </script>

  <style is:global>
  :root {
    --steam-bg: #080c11;
    --steam-blue: #66c0f4;
    --steam-glow: rgba(102,192,244,0.15);
  }

  .settings-page {
    position: relative;
    height: 100vh;
    width: 100vw;
    background: radial-gradient(circle at 50% -20%, var(--steam-glow) 0%, rgba(8, 12, 17, 0.42) 60%, var(--steam-bg) 90%);
    display: flex;
    flex-direction: column;
    padding: 50px 80px;
    overflow: hidden;
    color: #f3f3f3;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 15px 20px 15px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.04);
    margin-bottom: 30px;
  }
  .header h1 {
    font-size: 15px;
    font-weight: 800;
    color: #a4b4c4;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0;
  }

  .close-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.08);
    background: rgba(11, 19, 28, 0.75);
    color: #8291a1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .close-btn:hover {
    border-color: #ffffff;
    color: #fff;
    background: rgba(22, 36, 53, 0.95);
  }

  .options-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 10px 15px;
    overflow-y: auto;
  }
  .options-container::-webkit-scrollbar { display: none; }

  /* ESTILO BASE DE TARJETAS */
  .steam-card {
    position: relative;
    border-radius: 10px;
    border: 2px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 8px 16px rgba(0,0,0,0.3);
    transition: all 0.2s cubic-bezier(0.15, 0.85, 0.45, 1);
  }

  /* BOTONES DE OPCIONES CON DEGRADADO TORNASOL ROJO MUY LEVE */
  .variant-tornasol {
    background: linear-gradient(125deg, #121922 0%, #10141b 40%, rgba(235, 52, 82, 0.04) 100%);
    width: 100%;
    padding: 20px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .variant-tornasol:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: linear-gradient(125deg, #16202c 0%, #10141b 50%, rgba(235, 52, 82, 0.08) 100%);
  }

  /* EL NUEVO EFECTO DE ENFOQUE PROPIO (MANDO): Escala mínima, sin borde blanco duro */
  .has-custom-focus .steam-card:focus {
    outline: none !important;
    transform: scale(1.008) !important;
    border-color: rgba(235, 52, 82, 0.6) !important; 
    box-shadow: 0 0 15px rgba(235, 52, 82, 0.25), inset 0 0 8px rgba(235, 52, 82, 0.15) !important;
    z-index: 5;
  }

  .option-label {
    font-size: 16px;
    font-weight: 700;
    color: #f0f4f8;
  }

  .option-value {
    color: #8291a1;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.5px;
    padding: 6px 16px;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .option-value.badge-active {
    color: #fff;
    background: rgba(235, 52, 82, 0.6);
    border-color: rgba(235, 52, 82, 0.8);
  }

  .folder-path {
    max-width: 400px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: ui-monospace, Consolas, monospace;
    font-size: 12px;
    color: #a4b4c4;
  }

  /* PIE DE PÁGINA */
  .footer-section {
    margin-top: auto;
    padding-top: 24px;
    display: flex;
    justify-content: flex-start;
  }

  /* BOTÓN SALIR CON TORNASOL ROJO MÁS MARCADO PERO AJUSTADO */
  .variant-quit-tornasol {
    display: flex;
    align-items: center;
    gap: 10px;
    width: auto;
    min-width: 130px;
    padding: 12px 24px;
    background: linear-gradient(125deg, rgba(235, 52, 82, 0.08) 0%, #11151c 60%, rgba(235, 52, 82, 0.15) 100%);
    border-color: rgba(235, 52, 82, 0.25);
    color: #ff526e;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .variant-quit-tornasol:hover {
    background: linear-gradient(125deg, rgba(235, 52, 82, 0.15) 0%, #141a24 60%, rgba(235, 52, 82, 0.22) 100%);
    border-color: rgba(235, 52, 82, 0.4);
  }
  .has-custom-focus .variant-quit-tornasol:focus {
    border-color: #ff526e !important;
    box-shadow: 0 0 20px rgba(235, 52, 82, 0.4) !important;
    background: linear-gradient(125deg, rgba(235, 52, 82, 0.25) 0%, #121720 100%) !important;
  }
  
  .variant-quit-tornasol svg {
    width: 16px;
    height: 16px;
  }
  </style>
</Layout>