---
import { readFileSync } from 'node:fs'
import { resolve } from 'node:path'

const controllerB64 = readFileSync(resolve('src/assets/controller.png')).toString('base64')
const triggersB64 = readFileSync(resolve('src/assets/triggers.png')).toString('base64')

interface Pointer { id: string; startX: number; startY: number; dotX: number; dotY: number; }
interface Props { pointers: Pointer[]; }
const { pointers = [] } = Astro.props;
---

<div class="gx-diagram-core">
  <div class="gx-image-stack">
    <div class="gx-img-box-top"><img src={`data:image/png;base64,${triggersB64}`} alt="" /></div>
    <div class="gx-img-box-main"><img src={`data:image/png;base64,${controllerB64}`} alt="" /></div>
    
    <svg class="gx-lines-svg" viewBox="0 0 100 100">
      {pointers.map((p) => (
        <g>
          <line x1={`${p.startX}%`} y1={`${p.startY}%`} x2={`${p.dotX}%`} y2={`${p.dotY}%`} class="neon-line" />
          <circle cx={`${p.dotX}%`} cy={`${p.dotY}%`} r="0.8" class="neon-dot" />
        </g>
      ))}
    </svg>
  </div>
</div>

<style is:inline>
  .gx-diagram-core { 
    position: relative; 
    width: 100%; 
    height: 100%; 
    display: flex; 
    align-items: center; 
    justify-content: center;
  }

  .gx-image-stack { 
    position: relative; 
    width: 100%; 
    max-width: 480px; /* AUMENTADO: Hace el mando más grande */
    margin: 0 auto;
    transform: translateY(-8%); /* CORRECCIÓN: Sube el ensamble para quitar el espacio vacío arriba */
    z-index: 2; 
  }
  
  .gx-img-box-top { width: 58%; margin: 0 auto; transform: translateY(6%); }
  .gx-img-box-main { width: 85%; margin: 0 auto; }
  
  img { width: 100%; display: block; filter: drop-shadow(0 0 10px rgba(255, 34, 85, 0.3)); }
  
  .gx-lines-svg {
    position: absolute; 
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 100%; 
    aspect-ratio: 1 / 1; /* MAGIA: Esto bloquea el sistema de coordenadas a un cuadrado a prueba de zooms */
    pointer-events: none; 
    z-index: 5;
    overflow: visible; /* CRUCIAL: Permite que las líneas salgan de la caja para tocar los indicadores */
  }

  .neon-line { stroke: var(--gx-neon-red); stroke-width: 0.3; opacity: 0.7; }
  .neon-dot { fill: #ffffff; filter: drop-shadow(0 0 2px var(--gx-neon-red)); }
</style>